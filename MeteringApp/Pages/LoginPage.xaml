<Page x:Class="MeteringApp.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MeteringApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid>
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Логин" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Margin="0,0,70,0"></TextBlock>
            <TextBox x:Name="LoginBox" Width="120" Height="20" Margin="10"></TextBox>
            <TextBlock Text="Пароль" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Margin="0,0,35,0"></TextBlock>
            <PasswordBox x:Name="PassBox" Width="120" Height="20" Margin="10"></PasswordBox>
            <Button Content="Войти" FontSize="20" x:Name="BtnLogin" Click="BtnLogin_Click" VerticalAlignment="Center"></Button>
        </StackPanel>
    </Grid>
</Page>
